---
import Layout from "../../layouts/Layout.astro";

const diensten = [
  {
    slug: "automations",
    title: "Automations",
    description: "Handmatige, terugkerende processen automatiseer ik met workflows. Denk aan leads verwerken, rapportages versturen, data overzetten of notificaties triggeren. Het resultaat: minder handwerk, minder fouten, en uren terug per week.",
    iconBg: "bg-volt",
    iconColor: "#191A23",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>`,
  },
  {
    slug: "integrations",
    title: "Integraties",
    description: "Jouw CRM weet niet wat er in je boekhouding zit. Je webshop praat niet met je voorraadsysteem. Ik koppel systemen via APIs en webhooks zodat data automatisch stroomt. Geen dubbele invoer, geen verouderde gegevens.",
    iconBg: "bg-onyx",
    iconColor: "#B9FF66",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>`,
  },
  {
    slug: "custom-software",
    title: "Custom Software",
    description: "Standaardpakketten kosten te veel en doen net niet wat jij nodig hebt. Ik bouw mini SaaS-tools, dashboards en klantportalen die precies aansluiten op jouw werkproces. Gebouwd met Next.js en Supabase, gehost in de EU, volledig van jou.",
    iconBg: "bg-volt",
    iconColor: "#191A23",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  },
  {
    slug: "ai-solutions",
    title: "AI Oplossingen",
    description: "AI werkt alleen als het echt in je workflow zit. Ik bouw AI-integraties die documenten verwerken, data analyseren of klantcommunicatie ondersteunen, rechtstreeks in de tools die je al gebruikt. Geen losse chatbot, maar meetbaar resultaat.",
    iconBg: "bg-onyx",
    iconColor: "#B9FF66",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96-.46 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 4.44-1.14Z"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96-.46 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-4.44-1.14Z"/></svg>`,
  },
];
---

<Layout
  title="Diensten — Broere AI Solutions"
  description="Workflow automatisering, systeem integraties, maatwerk software en AI-oplossingen voor MKB. Concrete quick wins die direct resultaat opleveren."
>
  <div class="diensten-page text-onyx">
    <div class="absolute inset-0 pointer-events-none diensten-bg" aria-hidden="true"></div>
    <div class="absolute inset-0 pointer-events-none guides" aria-hidden="true"></div>

    <div class="relative mx-auto w-full max-w-[1200px] px-6 lg:px-10 pt-14 lg:pt-20 pb-24 lg:pb-32">

      <!-- Header -->
      <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <div class="inline-flex items-center gap-2 text-[11px] font-medium uppercase tracking-[0.06em] text-onyx/40">
            <span class="h-1.5 w-1.5 rounded-full bg-volt" aria-hidden="true"></span>
            Alle diensten
          </div>
          <h1 class="mt-5 font-bold tracking-[-0.035em] leading-[1] page-title text-onyx">
            Wat ik voor<br />je doe.
          </h1>
        </div>
        <p class="max-w-xs text-[15px] leading-[1.6] text-onyx/45 lg:text-right lg:mb-1">
          Klik op een dienst om meer te lezen.
        </p>
      </div>

      <!-- Cards: horizontal, stacked -->
      <ul class="mt-16 lg:mt-20 flex flex-col gap-6">
        {diensten.map((dienst) => (
          <li class="group pt-8">
            <a
              href={`/diensten/${dienst.slug}`}
              class="relative flex flex-col lg:flex-row lg:items-center lg:gap-10 bg-white border border-[#E5E5E5] rounded-2xl pt-14 pb-7 px-6 lg:py-7 lg:px-8 hover:shadow-[0_8px_32px_rgba(25,26,35,0.09)] hover:-translate-y-0.5 transition-all duration-200"
            >
              <!-- Floating icon (same position as homepage) -->
              <div
                class={`absolute -top-7 left-6 lg:left-8 w-14 h-14 rounded-2xl ${dienst.iconBg} flex items-center justify-center shadow-[0_4px_16px_rgba(25,26,35,0.12)]`}
                style={`color: ${dienst.iconColor}`}
                set:html={dienst.icon}
              />

              <!-- Title -->
              <h2 class="font-bold text-[19px] tracking-[-0.03em] text-onyx lg:w-44 lg:flex-none">
                {dienst.title}
              </h2>

              <!-- Divider (desktop only) -->
              <div class="hidden lg:block h-10 w-px bg-[#E5E5E5] flex-none" aria-hidden="true"></div>

              <!-- Description -->
              <p class="mt-3 lg:mt-0 text-[14px] text-onyx/55 leading-[1.65] flex-1">
                {dienst.description}
              </p>

              <!-- Lees meer -->
              <div class="mt-6 lg:mt-0 lg:flex-none inline-flex items-center gap-2 text-[13px] font-semibold text-onyx/35 group-hover:text-onyx transition-colors duration-200 whitespace-nowrap">
                Lees meer
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform duration-200">
                  <line x1="7" y1="17" x2="17" y2="7"/>
                  <polyline points="7 7 17 7 17 17"/>
                </svg>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- CTA -->
    <div class="relative bg-white px-6 lg:px-10">
      <div class="mx-auto w-full max-w-[1200px] py-16 lg:py-20 flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
        <div>
          <h2 class="font-bold tracking-[-0.025em] text-onyx cta-title">
            Weet je nog niet wat je nodig hebt?
          </h2>
          <p class="mt-3 max-w-md text-[15px] leading-[1.6] text-onyx/55">
            Plan een vrijblijvend kennismakingsgesprek. We bespreken je situatie en ik denk mee over wat het meeste oplevert.
          </p>
        </div>
        <a
          href="/contact"
          class="inline-flex flex-none items-center gap-3 rounded-[10px] bg-onyx px-6 py-3.5 text-[15px] font-semibold text-white transition-all hover:-translate-y-0.5 hover:shadow-[0_6px_16px_rgba(25,26,35,0.18)]"
        >
          Plan een gesprek
          <span class="flex h-5 w-5 items-center justify-center rounded-full bg-volt text-onyx" aria-hidden="true">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <line x1="7" y1="17" x2="17" y2="7"/>
              <polyline points="7 7 17 7 17 17"/>
            </svg>
          </span>
        </a>
      </div>
    </div>
  </div>
</Layout>

<style>
  .diensten-page {
    position: relative;
    isolation: isolate;
    overflow: hidden;
  }

  .diensten-bg {
    background-color: #F3F3F3;
    background-image:
      radial-gradient(ellipse 60% 40% at 90% 0%, rgba(185, 255, 102, 0.18), transparent 60%),
      radial-gradient(ellipse 40% 30% at 5% 100%, rgba(185, 255, 102, 0.1), transparent 60%);
  }

  .guides {
    background-image: linear-gradient(
      to right,
      rgba(25, 26, 35, 0.04) 1px,
      transparent 1px
    );
    background-size: 12.5% 100%;
  }

  .page-title {
    font-size: clamp(2.75rem, 7vw, 5rem);
    line-height: 1;
  }

  .cta-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
  }
</style>
