---
import Layout from "../../layouts/Layout.astro";

const resultaten = [
  {
    title: "Uren per week teruggewonnen",
    description: "Taken die nu handmatig worden gedaan, lopen straks automatisch — ook 's nachts en in het weekend.",
  },
  {
    title: "Foutloos en consistent",
    description: "Automatische processen maken geen typfouten, vergeten geen stap en werken elke keer exact hetzelfde.",
  },
  {
    title: "Schaalbaar bij groei",
    description: "Of je nu 10 of 1000 orders per dag verwerkt: de workflow schaalt mee zonder extra handen.",
  },
  {
    title: "Snel inzicht in wat er loopt",
    description: "Elke automatisering is traceerbaar. Je ziet precies wanneer iets is uitgevoerd en wat het resultaat was.",
  },
];

const useCases = [
  {
    trigger: "Je doet elke week dezelfde stappen",
    example: "Maandelijks handmatig rapportages exporteren, aanpassen en versturen naar klanten.",
  },
  {
    trigger: "Leads of bestellingen worden handmatig verwerkt",
    example: "Een contactformulier dat binnenkomt als mail die je zelf in het CRM invoert.",
  },
  {
    trigger: "Notificaties die je nu handmatig verstuurt",
    example: "Elke keer als een project klaar is, stuur jij zelf een mail. Dat kan automatisch.",
  },
  {
    trigger: "Data die tussendoor gestript of omgezet moet worden",
    example: "Exports uit tool A die je elke keer herformatteert voor import in tool B.",
  },
];

const stappen = [
  {
    nr: "01",
    titel: "Processen in kaart",
    tekst: "We bespreken welke taken je doet, hoe vaak, hoelang ze duren en welke tools er bij betrokken zijn.",
  },
  {
    nr: "02",
    titel: "Quick win identificeren",
    tekst: "Ik zoek de automatisering die de meeste tijd bespaart met de minste complexiteit. Dat wordt de eerste sprint.",
  },
  {
    nr: "03",
    titel: "Bouwen en testen",
    tekst: "De workflow wordt gebouwd en uitgebreid getest met echte data — inclusief foutafhandeling.",
  },
  {
    nr: "04",
    titel: "Live en gemonitord",
    tekst: "Na go-live houd ik het een week in de gaten. Je krijgt documentatie en weet precies wat er draait.",
  },
];

const tools = ["n8n", "Make", "Zapier", "Python", "REST APIs", "Webhooks", "cron jobs"];
---

<Layout
  title="Workflow Automatisering voor MKB — Broere AI Solutions"
  description="Repetitief werk automatiseren met n8n, Make en custom scripts. Bespaar uren per week met slimme workflow-automatiseringen die foutloos en schaalbaar werken."
>
  <!-- Hero -->
  <section class="bg-canvas relative overflow-hidden">
    <div class="dot-grid absolute inset-0 pointer-events-none" aria-hidden="true"></div>
    <div class="relative mx-auto w-full max-w-[1200px] px-6 lg:px-10 pt-10 lg:pt-14 pb-16 lg:pb-24">
      <a
        href="/diensten"
        class="inline-flex items-center gap-2 text-[13px] font-medium text-onyx/45 hover:text-onyx transition-colors"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Alle diensten
      </a>

      <div class="mt-8">
        <span class="font-sans font-medium text-[11px] uppercase tracking-[0.06em] text-onyx/40">Dienst · 01</span>
        <h1 class="mt-4 font-bold tracking-[-0.04em] leading-[0.93] page-title text-onyx">
          <span class="inline-block bg-volt px-[0.12em] rounded-[0.1em]">Automations</span>
        </h1>
        <p class="mt-6 max-w-[42ch] text-[clamp(1.05rem,1.8vw,1.25rem)] font-semibold tracking-[-0.02em] leading-[1.35] text-onyx">
          Repetitief werk dat jij nu nog doet, laat je voortaan automatisch lopen.
        </p>
        <p class="mt-4 max-w-[46ch] text-[15px] leading-[1.65] text-onyx/55">
          Workflows gebouwd met n8n, Make of custom scripts. Afhankelijk van wat het beste past bij jouw situatie en systemen.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="/contact"
            class="inline-flex items-center gap-3 rounded-[10px] bg-onyx px-5 py-3.5 text-[14px] font-semibold text-white shadow-[0_4px_16px_rgba(25,26,35,0.14)] transition-all hover:-translate-y-0.5 hover:shadow-[0_8px_24px_rgba(25,26,35,0.2)]"
          >
            Plan een gesprek
            <span class="inline-flex h-5 w-5 items-center justify-center rounded-full bg-volt text-onyx" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <line x1="7" y1="17" x2="17" y2="7"></line>
                <polyline points="7 7 17 7 17 17"></polyline>
              </svg>
            </span>
          </a>
          <a
            href="/projecten"
            class="inline-flex items-center gap-2 rounded-[10px] border border-onyx/15 px-5 py-3.5 text-[14px] font-semibold text-onyx/70 transition-all hover:border-onyx/30 hover:text-onyx hover:-translate-y-0.5"
          >
            Bekijk projecten
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Wat je krijgt -->
  <section class="bg-white py-20 lg:py-28">
    <div class="mx-auto w-full max-w-[1200px] px-6 lg:px-10">
      <h2 class="section-heading font-bold tracking-[-0.03em] text-onyx leading-[1.05]">
        Wat je <span class="inline-block bg-volt px-[0.12em] rounded-[0.08em]">krijgt</span>
      </h2>
      <div class="mt-12 lg:mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {resultaten.map((item) => (
          <div class="rounded-2xl border border-[#E5E5E5] bg-canvas/60 p-6">
            <span class="block w-2 h-2 rounded-full bg-volt mb-4"></span>
            <h3 class="font-semibold text-[16px] tracking-[-0.02em] text-onyx leading-[1.2]">
              {item.title}
            </h3>
            <p class="mt-3 text-[14px] leading-[1.6] text-onyx/55">
              {item.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Wanneer heb je dit nodig -->
  <section class="bg-canvas relative overflow-hidden py-20 lg:py-28">
    <div class="line-grid absolute inset-0 pointer-events-none" aria-hidden="true"></div>
    <div class="relative mx-auto w-full max-w-[1200px] px-6 lg:px-10">
      <h2 class="section-heading font-bold tracking-[-0.03em] text-onyx leading-[1.05]">
        Wanneer heb je <span class="inline-block bg-onyx text-white px-[0.12em] rounded-[0.08em]">dit nodig?</span>
      </h2>
      <div class="mt-12 lg:mt-16 grid gap-5 lg:grid-cols-2">
        {useCases.map((item) => (
          <div class="rounded-2xl bg-white border border-[#E5E5E5] p-7">
            <p class="font-semibold text-[16px] tracking-[-0.02em] text-onyx leading-[1.3]">
              {item.trigger}
            </p>
            <p class="mt-3 text-[14px] leading-[1.6] text-onyx/55 italic">
              Voorbeeld: {item.example}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Hoe ik het aanpak -->
  <section class="bg-white py-20 lg:py-28">
    <div class="mx-auto w-full max-w-[1200px] px-6 lg:px-10">
      <h2 class="section-heading font-bold tracking-[-0.03em] text-onyx leading-[1.05]">
        Hoe ik het <span class="inline-block bg-volt px-[0.12em] rounded-[0.08em]">aanpak</span>
      </h2>
      <div class="mt-12 lg:mt-16 grid gap-0">
        {stappen.map((stap, i) => (
          <div class={`flex gap-6 lg:gap-10 py-8 ${i < stappen.length - 1 ? "border-b border-[#E5E5E5]" : ""}`}>
            <span class="font-mono text-[13px] tracking-[0.1em] text-onyx/25 flex-none pt-1">{stap.nr}</span>
            <div>
              <h3 class="font-semibold text-[18px] tracking-[-0.025em] text-onyx">{stap.titel}</h3>
              <p class="mt-2 text-[15px] leading-[1.65] text-onyx/55 max-w-[52ch]">{stap.tekst}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Tools -->
      <div class="mt-16 pt-10 border-t border-[#E5E5E5]">
        <span class="font-sans font-medium text-[11px] uppercase tracking-[0.06em] text-onyx/35">Tools & technologie</span>
        <div class="mt-4 flex flex-wrap gap-2">
          {tools.map((tool) => (
            <span class="rounded-md border border-onyx/10 bg-canvas px-3 py-1.5 text-[12px] font-mono text-onyx/60">
              {tool}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-onyx py-20 lg:py-28">
    <div class="mx-auto w-full max-w-[1200px] px-6 lg:px-10">
      <div class="flex flex-col gap-8 lg:flex-row lg:items-center lg:justify-between">
        <div class="max-w-[46ch]">
          <h2 class="cta-title font-bold tracking-[-0.03em] text-white leading-[1.1]">
            Klaar voor minder <span class="bg-volt text-onyx px-[0.15em] rounded-[0.1em]">handwerk?</span>
          </h2>
          <p class="mt-5 text-[16px] leading-[1.65] text-white/55">
            Plan een vrijblijvend gesprek. We bespreken welke processen bij jou de meeste tijd kosten en waar automatisering het meeste oplevert.
          </p>
        </div>
        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href="/contact"
            class="inline-flex items-center justify-center gap-3 rounded-[10px] bg-volt px-6 py-4 text-[15px] font-semibold text-onyx shadow-[0_4px_16px_rgba(185,255,102,0.25)] transition-all hover:-translate-y-0.5 hover:shadow-[0_8px_24px_rgba(185,255,102,0.3)]"
          >
            Plan een afspraak
            <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-onyx text-volt" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <line x1="7" y1="17" x2="17" y2="7"></line>
                <polyline points="7 7 17 7 17 17"></polyline>
              </svg>
            </span>
          </a>
          <a
            href="mailto:bas@broere.ai"
            class="inline-flex items-center justify-center gap-2 rounded-[10px] border border-white/15 px-6 py-4 text-[15px] font-semibold text-white/80 transition-all hover:border-white/30 hover:text-white hover:-translate-y-0.5"
          >
            bas@broere.ai
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .dot-grid {
    background-image: radial-gradient(circle, rgba(25, 26, 35, 0.07) 1px, transparent 1px);
    background-size: 28px 28px;
  }

  .line-grid {
    background-image:
      repeating-linear-gradient(to right, rgba(25, 26, 35, 0.05) 0px, rgba(25, 26, 35, 0.05) 1px, transparent 1px, transparent 64px),
      repeating-linear-gradient(to bottom, rgba(25, 26, 35, 0.05) 0px, rgba(25, 26, 35, 0.05) 1px, transparent 1px, transparent 64px);
  }

  .page-title {
    font-size: clamp(3rem, 8vw, 6.5rem);
  }

  .section-heading {
    font-size: clamp(2rem, 5vw, 3.5rem);
  }

  .cta-title {
    font-size: clamp(1.8rem, 3.5vw, 2.5rem);
  }
</style>
